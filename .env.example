POSTGRES_DB=chatdb
POSTGRES_USER=chat
POSTGRES_PASSWORD_FILE=./secrets/postgres_password.txt

REDIS_URL=redis://redis:6379/0
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=chat.events
EVENT_CONSUMER_GROUP=chat-event-audit
CHAT_HISTORY_CONSUMER_GROUP=chat-history-writer
MODERATION_CONSUMER_GROUP=chat-moderation
MODERATION_BLOCKED_WORDS=spam,scam
MODERATION_MAX_MESSAGE_LENGTH=500
MODERATION_DUPLICATE_WINDOW_SECONDS=30
MODERATION_FLOOD_WINDOW_SECONDS=10
MODERATION_FLOOD_MESSAGE_THRESHOLD=5

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD_FILE=./secrets/grafana_admin_password.txt

AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD_FILE=./secrets/airflow_admin_password.txt
AIRFLOW_POSTGRES_USER=airflow
AIRFLOW_POSTGRES_DB=airflow
AIRFLOW_POSTGRES_PASSWORD_FILE=./secrets/airflow_postgres_password.txt
